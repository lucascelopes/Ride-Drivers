<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Ride For Drivers</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Ride For Drivers</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <!-- Google Maps/Navigation API Key (recomendo rotacionar e restringir por Bundle ID) -->
    <key>GMSApiKey</key>
    <string>***SUA_API_KEY_RESTRITA***</string>
    <!-- Permissões de localização (as 3 — Always é legacy mas ainda ajuda em aparelhos antigos) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>We use your location and heading to provide turn-by-turn navigation and rotate the map as you drive.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>We use your location and heading to provide turn-by-turn navigation and rotate the map as you drive.</string>
    <key>NSLocationAlwaysUsageDescription</key>
    <string>We use your location and heading to provide turn-by-turn navigation and rotate the map as you drive.</string>
    <!-- Background Modes: navegação contínua (voz + updates) -->
    <key>UIBackgroundModes</key>
    <array>
      <string>location</string>
      <string>audio</string>
    </array>
    <!-- iOS 14+: precisão temporária (se pedir requestTemporaryFullAccuracyAuthorization) -->
    <key>NSLocationTemporaryUsageDescriptionDictionary</key>
    <dict>
      <key>Navigation</key>
      <string>We need precise location temporarily to provide accurate turn-by-turn guidance.</string>
    </dict>
    <!-- Outras permissões que você já usa -->
    <key>NSCameraUsageDescription</key>
    <string>To take a picture or video, we need access to the camera.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>To upload data, we need access to your photo library.</string>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <!-- Se você NÃO usa storyboard "Main", pode remover -->
    <!-- <key>UIMainStoryboardFile</key><string>Main</string> -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
      <string>UIInterfaceOrientationLandscapeLeft</string>
      <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
      <string>UIInterfaceOrientationPortraitUpsideDown</string>
      <string>UIInterfaceOrientationLandscapeLeft</string>
      <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>FlutterDeepLinkingEnabled</key>
    <true/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
  </dict>
</plist>