<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" package="com.quicky.ridedriver">
  <!-- Rede -->
  <uses-permission android:name="android.permission.INTERNET"/>
  <!-- Localização (foreground) -->
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
  <!-- Localização em background (Android 10+) -->
  <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
  <!-- Serviços em primeiro plano (Android 9+/10+/14+) -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
  <!-- Câmera (só mantenha se realmente usa) -->
  <uses-permission android:name="android.permission.CAMERA"/>
  <!-- Bússola opcional; não é obrigatória pro Navigation SDK -->
  <uses-feature android:name="android.hardware.sensor.compass" android:required="false"/>
  <!-- Se você NÃO precisa mexer com arquivos antigos, REMOVA as permissões abaixo e o requestLegacyExternalStorage
         Caso precise MESMO, mantenha com maxSdkVersion=32 como está: -->
  <!--
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    -->
  <application
    android:label="Ride For Drivers"
    android:icon="@mipmap/ic_launcher"
    tools:replace="android:label"
  >
    <!-- Chave de API do Google (Navigation/Maps) -->
    <meta-data android:name="com.google.android.geo.API_KEY" android:value="AIzaSyCFBfcNHFg97sM7EhKnAP4OHIoY3Q8Y_xQ"/>
    <activity android:name=".MainActivity" android:exported="true" android:launchMode="singleTop" android:theme="@style/LaunchTheme" android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode" android:hardwareAccelerated="true" android:windowSoftInputMode="adjustResize">
      <!-- Tema inicial enquanto o Flutter renderiza -->
      <meta-data android:name="io.flutter.embedding.android.NormalTheme" android:resource="@style/NormalTheme"/>
      <!-- Splash -->
      <meta-data android:name="io.flutter.embedding.android.SplashScreenDrawable" android:resource="@drawable/launch_background"/>
      <!-- Deep linking -->
      <meta-data android:name="flutter_deeplinking_enabled" android:value="true"/>
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data android:scheme="ridefordrivers" android:host="ridefordrivers.com"/>
      </intent-filter>
    </activity>
    <!-- Não delete: usado pelo Flutter para registrar plugins -->
    <meta-data android:name="flutterEmbedding" android:value="2"/>
  </application>
</manifest>